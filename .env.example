# Saud's MCI Platform - Environment Variables
# Copy this file to .env and fill in the required values.

# Application port (default: 3000)
APP_PORT=3000

# MySQL database credentials
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=mci_platform
MYSQL_USER=mci_user
MYSQL_PASSWORD=change_me_db_password

# Auth - REQUIRED
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# Manus OAuth - OPTIONAL (leave blank for custom auth only)
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# Manus Forge API - OPTIONAL (for LLM/storage features)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Analytics - OPTIONAL
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
