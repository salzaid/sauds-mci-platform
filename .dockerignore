# Node modules — reinstalled inside the container
**/node_modules

# Build output — produced inside the container
dist/
build/

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Dev/test artefacts
*.log
coverage/
.nyc_output/
.cache/
.parcel-cache/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Git history — not needed in the image
.git/
.gitignore

# Manus platform artefacts
.webdev/
.manus-logs/
.project-config.json
client/public/__manus__/

# TypeScript incremental build cache
*.tsbuildinfo

# Test files — not needed in production image
**/*.test.ts
**/*.spec.ts
vitest.config.ts
